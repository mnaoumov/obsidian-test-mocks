{
  "name": "obsidian-test-mocks",
  "version": "3.3.0",
  "description": "Comprehensive test mocks for the Obsidian API.",
  "keywords": [
    "obsidian",
    "testing",
    "mocks",
    "vitest",
    "jest"
  ],
  "homepage": "https://github.com/mnaoumov/obsidian-test-mocks#readme",
  "bugs": {
    "url": "https://github.com/mnaoumov/obsidian-test-mocks/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mnaoumov/obsidian-test-mocks.git"
  },
  "license": "MIT",
  "author": "Michael Naumov",
  "type": "module",
  "exports": {
    "./jest-setup": {
      "import": {
        "types": "./dist/lib/esm/globals/jest-setup.d.mts",
        "default": "./dist/lib/esm/globals/jest-setup.mjs"
      },
      "require": {
        "types": "./dist/lib/cjs/globals/jest-setup.d.cts",
        "default": "./dist/lib/cjs/globals/jest-setup.cjs"
      }
    },
    "./obsidian-typings/jest-setup": {
      "import": {
        "types": "./dist/lib/esm/obsidian-typings/jest-setup.d.mts",
        "default": "./dist/lib/esm/obsidian-typings/jest-setup.mjs"
      },
      "require": {
        "types": "./dist/lib/cjs/obsidian-typings/jest-setup.d.cts",
        "default": "./dist/lib/cjs/obsidian-typings/jest-setup.cjs"
      }
    },
    "./obsidian-typings/setup": {
      "import": {
        "types": "./dist/lib/esm/obsidian-typings/setup.d.mts",
        "default": "./dist/lib/esm/obsidian-typings/setup.mjs"
      },
      "require": {
        "types": "./dist/lib/cjs/obsidian-typings/setup.d.cts",
        "default": "./dist/lib/cjs/obsidian-typings/setup.cjs"
      }
    },
    "./obsidian-typings/vitest-setup": {
      "import": {
        "types": "./dist/lib/esm/obsidian-typings/vitest-setup.d.mts",
        "default": "./dist/lib/esm/obsidian-typings/vitest-setup.mjs"
      },
      "require": {
        "types": "./dist/lib/cjs/obsidian-typings/vitest-setup.d.cts",
        "default": "./dist/lib/cjs/obsidian-typings/vitest-setup.cjs"
      }
    },
    "./obsidian": {
      "import": {
        "types": "./dist/lib/esm/obsidian/index.d.mts",
        "default": "./dist/lib/esm/obsidian/index.mjs"
      },
      "require": {
        "types": "./dist/lib/cjs/obsidian/index.d.cts",
        "default": "./dist/lib/cjs/obsidian/index.cjs"
      }
    },
    "./setup": {
      "import": {
        "types": "./dist/lib/esm/globals/setup.d.mts",
        "default": "./dist/lib/esm/globals/setup.mjs"
      },
      "require": {
        "types": "./dist/lib/cjs/globals/setup.d.cts",
        "default": "./dist/lib/cjs/globals/setup.cjs"
      }
    },
    "./vitest-setup": {
      "import": {
        "types": "./dist/lib/esm/globals/vitest-setup.d.mts",
        "default": "./dist/lib/esm/globals/vitest-setup.mjs"
      },
      "require": {
        "types": "./dist/lib/cjs/globals/vitest-setup.d.cts",
        "default": "./dist/lib/cjs/globals/vitest-setup.cjs"
      }
    }
  },
  "files": [
    "!dist/*.tgz",
    "**/package.json",
    "dist/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "jiti scripts/build.ts",
    "build:clean": "jiti scripts/build-clean.ts",
    "build:compile": "jiti scripts/build-compile.ts",
    "build:compile:typescript": "jiti scripts/build-compile-typescript.ts",
    "build:generate:indices": "jiti scripts/build-generate-indices.ts",
    "build:lib": "jiti scripts/build-lib.ts",
    "build:types": "jiti scripts/build-types.ts",
    "commit": "jiti scripts/commit.ts",
    "format": "jiti scripts/format.ts",
    "format:check": "jiti scripts/format-check.ts",
    "lint": "jiti scripts/lint.ts",
    "lint:fix": "jiti scripts/lint-fix.ts",
    "lint:md": "jiti scripts/lint-md.ts",
    "lint:md:fix": "jiti scripts/lint-md-fix.ts",
    "prepare": "jiti scripts/prepare.ts",
    "spellcheck": "jiti scripts/spellcheck.ts",
    "test": "jiti scripts/test.ts",
    "test:coverage": "jiti scripts/test-coverage.ts",
    "test:jest": "jiti scripts/test-jest.ts",
    "test:watch": "jiti scripts/test-watch.ts",
    "version": "jiti scripts/version.ts"
  },
  "overrides": {
    "eslint": "$eslint",
    "eslint-plugin-import": "$eslint-plugin-import-x",
    "js-yaml": "^4.2.0",
    "markdown-it": "^14.2.0",
    "type-fest": "$type-fest",
    "typescript": "$typescript"
  },
  "dependencies": {
    "@codemirror/state": "6.5.0",
    "@codemirror/view": "6.38.6",
    "moment": "2.29.4",
    "turndown": "^7.2.4",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@commitlint/types": "^21.1.0",
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.2",
    "@eslint/compat": "^2.1.0",
    "@eslint/config-helpers": "^0.6.0",
    "@eslint/js": "^10.0.1",
    "@jest/globals": "^30.4.1",
    "@obsidian-typings/obsidian-public-latest": "^6.18.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@total-typescript/ts-reset": "^0.6.1",
    "@tsconfig/strictest": "^2.0.8",
    "@types/markdown-it": "^14.1.2",
    "@types/semver": "^7.7.1",
    "@types/turndown": "^5.0.6",
    "@typescript-eslint/utils": "^8.62.0",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/runner": "4.1.0",
    "better-typescript-lib": "^2.12.0",
    "cspell": "^10.0.1",
    "czg": "^1.13.1",
    "dprint": "^0.55.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.17.0",
    "eslint-plugin-perfectionist": "^5.9.1",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "markdownlint": "^0.41.0",
    "markdownlint-cli2": "^0.22.1",
    "markdownlint-rule-relative-links": "^5.1.0",
    "nano-staged": "^1.0.2",
    "obsidian": "^1.13.1",
    "semver": "^7.8.5",
    "ts-jest": "^29.4.11",
    "type-fest": "^5.7.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "jest": "*",
    "obsidian": "^1.12.3",
    "vitest": "*"
  },
  "peerDependenciesMeta": {
    "jest": {
      "optional": true
    },
    "vitest": {
      "optional": true
    }
  }
}
